# Локально: backend/.env | На сервере: .env в корне (docker compose)
JARVIS_HOST=127.0.0.1
JARVIS_PORT=8000
JARVIS_DATA_DIR=./data

# Сервер: публичный URL и CORS (через запятую)
# JARVIS_PUBLIC_URL=https://jarvis.example.com
# JARVIS_CORS_ORIGINS=https://jarvis.example.com

# Telegram userbot / аналитик (https://my.telegram.org/apps)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
