# Скопируйте в .env рядом с docker-compose.yml (на сервере)
# Публичный URL сайта (для Mango/Telegram webhook, если понадобится)
JARVIS_PUBLIC_URL=https://jarvis.example.com

# CORS: домен, с которого открывают UI (через nginx — обычно тот же хост)
JARVIS_CORS_ORIGINS=https://jarvis.example.com

JARVIS_HOST=0.0.0.0
JARVIS_PORT=8000

# Ключи задаются в UI «Настройки» и пишутся в volume backend/data/settings.json
# Либо можно задать здесь (не коммитьте .env в git):
# DEEPSEEK_API_KEY=sk-...

# Telegram Bot API (опционально, можно в UI)
# TELEGRAM_BOT_TOKEN=

# Прокси к api.telegram.org (если сервер в РФ без прямого доступа)
# TELEGRAM_PROXY=socks5://127.0.0.1:10808
