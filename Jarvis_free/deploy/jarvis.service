[Unit]
Description=Jarvis AI Agent
After=network.target

[Service]
Type=simple
User=jarvis
WorkingDirectory=/opt/jarvis/backend
Environment=JARVIS_HOST=0.0.0.0
Environment=JARVIS_PORT=8000
Environment=JARVIS_DATA_DIR=/opt/jarvis/backend/data
ExecStart=/opt/jarvis/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 1
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
